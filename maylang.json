import React, { useState, useMemo, useEffect } from 'react';
import { motion } from 'motion/react';
import { 
  ChevronLeft, 
  ChevronRight, 
  Database, 
  Download, 
  Upload, 
  Trash2, 
  RefreshCcw, 
  Settings as SettingsIcon,
  Book,
  History,
  FileText,
  User as UserIcon,
  LogOut,
  LogIn,
  Check,
  Search,
  BookOpen
} from 'lucide-react';
import { User } from 'firebase/auth';
import { db } from '../db';
import { Vocabulary, Chapter } from '../types';
import { BOX_INTERVALS } from '../constants';
import { Modal } from './Modal';

interface SettingsViewProps {
  allVocab?: Vocabulary[];
  settings?: any[];
  onInstallBase: () => void;
  isImportingBase: boolean;
  baseStatus: string;
  onProcessData: (data: any[], sourceName: string, sourceGroup?: string) => Promise<void>;
  onExportData: () => Promise<void>;
  onDownloadTemplate: (format: 'xlsx' | 'csv') => Promise<void>;
  onImportFile: (e: React.ChangeEvent<HTMLInputElement>) => void;
  onImportFromGoogleSheets: () => Promise<void>;
  onInstallVerbenMitPraeposition: () => void;
  isImportingSpecial: boolean;
  status: string;
  setStatus: (s: string) => void;
  isImporting: boolean;
  gsUrl: string;
  setGsUrl: (url: string) => void;
  gsGroup: string;
  setGsGroup: (g: string) => void;
  t: (key: any) => string;
  language: string;
  viewMode?: 'vocab' | 'settings';
  onDownloadCourseBookChapter: (chapter: Chapter) => void;
  isDownloadingCourseBook: string | null;
  user: User | null;
  syncing: boolean;
  lastSyncTime: string | null;
  onLogin: () => void;
  onLogout: () => void;
  onSync: () => void;
  onShowPrivacy: () => void;
}

export const SettingsView = ({ 
  allVocab = [], 
  settings = [], 
  onInstallBase, 
  isImportingBase, 
  baseStatus,
  onProcessData,
  onExportData,
  onDownloadTemplate,
  onImportFile,
  onImportFromGoogleSheets,
  onInstallVerbenMitPraeposition,
  isImportingSpecial,
  status,
  setStatus,
  isImporting,
  gsUrl,
  setGsUrl,
  gsGroup,
  setGsGroup,
  t,
  language,
  viewMode = 'vocab',
  onDownloadCourseBookChapter,
  isDownloadingCourseBook,
  user,
  syncing,
  lastSyncTime,
  onLogin,
  onLogout,
  onSync,
  onShowPrivacy
}: SettingsViewProps) => {
  const [modalConfig, setModalConfig] = useState<{ 
    isOpen: boolean, 
    title: string, 
    children: React.ReactNode, 
    onConfirm: () => void, 
    type?: 'default' | 'danger' 
  }>({
    isOpen: false,
    title: '',
    children: null,
    onConfirm: () => {},
  });

  const dailyVocabLimit = (settings || []).find(s => s.key === 'daily_vocab_limit')?.value || 50;
  const dailyMinutesGoal = (settings || []).find(s => s.key === 'daily_minutes_goal')?.value || 15;
  const learningMode = (settings || []).find(s => s.key === 'learning_mode')?.value || 'time';
  const boxIntervals = (settings || []).find(s => s.key === 'box_intervals')?.value || BOX_INTERVALS;

  const updateSetting = async (key: string, value: any) => {
    await db.user_settings.put({ key, value });
    setStatus('Einstellung gespeichert.');
    setTimeout(() => setStatus(''), 3000);
  };

  const sources = useMemo(() => {
    const groups: Record<string, { count: number, hiddenCount: number, usedCount: number, group: string }> = {};
    (allVocab || []).forEach((v: any) => {
      const name = v.source_name || 'Manuell hinzugefügt';
      const group = v.source_group || '';
      if (!groups[name]) {
        groups[name] = { count: 0, hiddenCount: 0, usedCount: 0, group };
      }
      groups[name].count++;
      if (v.is_hidden) groups[name].hiddenCount++;
      if (v.box_level !== '1' || v.fehlerquote > 0) groups[name].usedCount++;
    });
    return Object.entries(groups).map(([name, stats]) => ({
      name,
      ...stats,
      isFullyHidden: stats.hiddenCount === stats.count,
      hasUsedVocab: stats.usedCount > 0
    }));
  }, [allVocab]);

  const groupedSources = useMemo(() => {
    const groups: Record<string, any[]> = {};
    sources.forEach(s => {
      const g = s.group || 'Einzelne Listen';
      if (!groups[g]) groups[g] = [];
      groups[g].push(s);
    });
    return Object.entries(groups).sort((a, b) => {
      if (a[0] === 'Einzelne Listen') return 1;
      if (b[0] === 'Einzelne Listen') return -1;
      return a[0].localeCompare(b[0]);
    });
  }, [sources]);

  const toggleSourceVisibility = async (sourceName: string, hide: boolean) => {
    const items = allVocab.filter((v: any) => (v.source_name || 'Manuell hinzugefügt') === sourceName);
    const updates = items.map((v: any) => ({ ...v, is_hidden: hide }));
    await db.vocabulary.bulkPut(updates);
    setStatus(`Vokabeln aus "${sourceName}" ${hide ? 'ausgeblendet' : 'eingeblendet'}.`);
  };

  const deleteSource = (sourceName: string) => {
    let resetStats = false;
    setModalConfig({
      isOpen: true,
      title: 'Liste löschen',
      type: 'danger',
      children: (
        <div className="space-y-4">
          <p>Möchtest du die Liste <span className="font-bold text-brand-dark">"{sourceName}"</span> und alle darin enthaltenen Vokabeln wirklich löschen?</p>
          <div className="p-4 bg-red-50 rounded-2xl border border-red-100 space-y-3">
            <label className="flex items-start gap-3 cursor-pointer group">
              <div className="relative flex items-center mt-0.5">
                <input 
                  type="checkbox" 
                  className="peer h-4 w-4 cursor-pointer appearance-none rounded border border-red-300 bg-white checked:bg-red-600 checked:border-red-600 transition-all"
                  onChange={(e) => { resetStats = e.target.checked; }}
                />
                <Check size={12} className="absolute left-0.5 top-0.5 text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" />
              </div>
              <div className="flex flex-col">
                <span className="text-xs font-bold text-red-600 uppercase tracking-wider">Dashboard zurücksetzen</span>
                <span className="text-[10px] text-red-600/70 leading-tight">Löscht auch alle Lernstatistiken und den Verlauf.</span>
              </div>
            </label>
          </div>
          <p className="text-[10px] text-brand-dark/50 italic">Diese Aktion kann nicht rückgängig gemacht werden.</p>
        </div>
      ),
      onConfirm: async () => {
        try {
          const itemsToDelete = allVocab.filter((v: any) => (v.source_name || 'Manuell hinzugefügt') === sourceName);
          const ids = itemsToDelete.map(v => v.id!).filter(id => id !== undefined);
          if (ids.length > 0) {
            await db.vocabulary.bulkDelete(ids);
            if (resetStats) {
              const now = new Date().toISOString();
              await db.transaction('rw', db.vocabulary, db.learning_history, db.learning_sessions, async () => {
                await db.learning_history.clear();
                await db.learning_sessions.clear();
                await db.vocabulary.toCollection().modify((v: any) => {
                  v.box_level = '1';
                  v.times_correct = 0;
                  v.times_incorrect = 0;
                  v.last_seen = undefined;
                  v.naechste_faelligkeit = now;
                  v.updatedAt = now;
                  v.resetAt = now;
                });
              });
              setStatus(`Liste "${sourceName}" gelöscht und Fortschritt zurückgesetzt.`);
            } else {
              setStatus(`Liste "${sourceName}" wurde gelöscht (${ids.length} Vokabeln).`);
            }
          } else {
            setStatus(`Keine Vokabeln in Liste "${sourceName}" gefunden.`);
          }
        } catch (err) {
          console.error('Delete error:', err);
          setStatus('Fehler beim Löschen der Liste.');
        }
      }
    });
  };

  const findDuplicates = () => {
    const groups: Record<string, Vocabulary[]> = {};
    allVocab.forEach((v: any) => {
      const key = `${v.grundform.trim().toLowerCase()}_${v.wortart}`;
      if (!groups[key]) groups[key] = [];
      groups[key].push(v);
    });

    const duplicates = Object.entries(groups)
      .filter(([_, items]) => items.length > 1)
      .map(([key, items]) => ({ key, items }));

    if (duplicates.length === 0) {
      setStatus('Keine Duplikate gefunden.');
      return;
    }

    let action: 'delete' | 'hide' = 'delete';

    setModalConfig({
      isOpen: true,
      title: 'Duplikate bereinigen',
      children: (
        <div className="space-y-4 max-h-96 overflow-y-auto custom-scrollbar pr-2">
          <p className="text-sm font-medium text-brand-dark">
            Es wurden {duplicates.length} Wort-Gruppen mit Duplikaten gefunden. 
            Wie möchtest du mit den Duplikaten verfahren?
          </p>
          
          <div className="flex gap-4 p-2 bg-brand/5 rounded-xl border border-brand/10">
            <button 
              onClick={() => { action = 'delete'; }}
              className="flex-1 btn-danger !py-2 !text-[10px]"
            >
              Löschen
            </button>
            <button 
              onClick={() => { action = 'hide'; }}
              className="flex-1 btn-secondary !py-2 !text-[10px]"
            >
              Ausblenden
            </button>
          </div>

          <p className="text-[10px] text-brand-dark/60 italic">
            * Jeweils die Vokabel mit dem höchsten Lernfortschritt bleibt erhalten/sichtbar.
          </p>

          <div className="space-y-2">
            {duplicates.slice(0, 5).map(dup => (
              <div key={dup.key} className="p-2 bg-brand/5 rounded-lg border border-brand/10">
                <p className="text-xs font-bold text-brand-dark">{dup.items[0].grundform} ({dup.items[0].wortart})</p>
                <p className="text-[10px] text-brand-dark/60">{dup.items.length} Einträge gefunden</p>
              </div>
            ))}
            {duplicates.length > 5 && <p className="text-[10px] text-brand/60 italic">... und {duplicates.length - 5} weitere.</p>}
          </div>
        </div>
      ),
      onConfirm: async () => {
        const idsToProcess: number[] = [];
        duplicates.forEach(dup => {
          const sorted = [...dup.items].sort((a, b) => {
            const getLevel = (lvl: string) => lvl === 'Archiv' ? 6 : parseInt(lvl);
            return getLevel(b.box_level) - getLevel(a.box_level);
          });
          sorted.slice(1).forEach(v => {
            if (v.id) idsToProcess.push(v.id);
          });
        });

        if (idsToProcess.length > 0) {
          if (action === 'delete') {
            await db.vocabulary.bulkDelete(idsToProcess);
            setStatus(`${idsToProcess.length} Duplikate erfolgreich gelöscht.`);
          } else {
            const updates = idsToProcess.map(id => {
              const v = allVocab.find(item => item.id === id);
              return v ? { ...v, is_hidden: true } : null;
            }).filter(v => v !== null) as Vocabulary[];
            await db.vocabulary.bulkPut(updates);
            setStatus(`${idsToProcess.length} Duplikate erfolgreich ausgeblendet.`);
          }
        }
      }
    });
  };

  const renameSource = (oldName: string) => {
    const sourceObj = sources.find(s => s.name === oldName);
    const oldGroup = sourceObj?.group || '';
    let newName = oldName;
    let newGroup = oldGroup;

    setModalConfig({
      isOpen: true,
      title: 'Liste bearbeiten',
      children: (
        <div className="space-y-4">
          <div className="space-y-2">
            <label className="text-[10px] font-bold text-brand-dark/60 uppercase tracking-widest">Name der Liste</label>
            <input 
              type="text" 
              defaultValue={oldName} 
              onChange={(e) => { newName = e.target.value; }}
              className="w-full px-4 py-2 rounded-lg border border-brand/20 focus:outline-none focus:border-brand text-sm"
            />
          </div>
          <div className="space-y-2">
            <label className="text-[10px] font-bold text-brand-dark/60 uppercase tracking-widest">Sammlung / Buch</label>
            <input 
              type="text" 
              defaultValue={oldGroup} 
              placeholder="z.B. Lehrbuch A1..."
              onChange={(e) => { newGroup = e.target.value; }}
              className="w-full px-4 py-2 rounded-lg border border-brand/20 focus:outline-none focus:border-brand text-sm"
            />
          </div>
        </div>
      ),
      onConfirm: async () => {
        if ((newName && newName !== oldName) || newGroup !== oldGroup) {
          const items = allVocab.filter((v: any) => (v.source_name || 'Manuell hinzugefügt') === oldName);
          const updates = items.map((v: any) => ({ 
            ...v, 
            source_name: newName,
            source_group: newGroup 
          }));
          await db.vocabulary.bulkPut(updates);
          setStatus(`Liste "${oldName}" wurde aktualisiert.`);
        }
      }
    });
  };

  const renameGroup = (oldGroup: string) => {
    let newGroup = oldGroup;
    setModalConfig({
      isOpen: true,
      title: 'Sammlung umbenennen',
      children: (
        <div className="space-y-2">
          <p className="text-sm text-brand-dark">Gib einen neuen Namen für die Sammlung ein:</p>
          <input 
            type="text" 
            defaultValue={oldGroup} 
            onChange={(e) => { newGroup = e.target.value; }}
            className="w-full px-4 py-2 rounded-lg border border-brand/20 focus:outline-none focus:border-brand text-sm"
          />
          <p className="text-[10px] text-brand-dark/60 italic">
            Dies ändert den Namen für alle Listen in dieser Sammlung.
          </p>
        </div>
      ),
      onConfirm: async () => {
        if (newGroup && newGroup !== oldGroup) {
          const items = allVocab.filter((v: any) => v.source_group === oldGroup);
          const updates = items.map((v: any) => ({ ...v, source_group: newGroup }));
          await db.vocabulary.bulkPut(updates);
          setStatus(`Sammlung wurde in "${newGroup}" umbenannt.`);
        }
      }
    });
  };

  const [expandedSections, setExpandedSections] = useState<Record<string, boolean>>({
    lists_mgmt: false,
    books_mgmt: false,
    intervals: false,
    feedback: false,
    all_vocab: false
  });

  const [expandedGroups, setExpandedGroups] = useState<Record<string, boolean>>({});

  const toggleGroup = (group: string) => {
    setExpandedGroups(prev => ({
      ...prev,
      [group]: !prev[group]
    }));
  };

  const toggleSection = (section: string) => {
    setExpandedSections(prev => ({
      ...prev,
      [section]: !prev[section]
    }));
  };

  const handleResetStats = () => {
    setModalConfig({
      isOpen: true,
      title: 'Statistiken zurücksetzen',
      type: 'danger',
      children: (
        <div className="space-y-4">
          <p className="text-sm text-brand-dark font-medium">
            Möchtest du wirklich alle Lernstatistiken, den Verlauf und die Sessions löschen?
          </p>
          <p className="text-xs text-brand-dark/60">
            Deine Vokabeln bleiben erhalten, aber das Dashboard wird komplett zurückgesetzt.
          </p>
        </div>
      ),
      onConfirm: async () => {
        const now = new Date().toISOString();
        await db.transaction('rw', db.vocabulary, db.learning_history, db.learning_sessions, async () => {
          await db.learning_history.clear();
          await db.learning_sessions.clear();
          await db.vocabulary.toCollection().modify((v: any) => {
            v.box_level = '1';
            v.times_correct = 0;
            v.times_incorrect = 0;
            v.last_seen = undefined;
            v.naechste_faelligkeit = now;
            v.updatedAt = now;
            v.resetAt = now;
          });
        });
        setStatus('Statistiken und Fortschritt wurden zurückgesetzt.');
      }
    });
  };

  const handleResetDB = () => {
    let confirmText = '';
    setModalConfig({
      isOpen: true,
      title: 'Datenbank zurücksetzen',
      type: 'danger',
      children: (
        <div className="space-y-4">
          <p className="text-sm text-brand-dark font-medium">
            Bist du sicher? Alle lokalen Daten werden unwiderruflich gelöscht.
          </p>
          <div className="p-4 bg-red-50 rounded-xl border border-red-100 space-y-2">
            <p className="text-[10px] text-red-600 font-bold uppercase tracking-wider">Sicherheitsbestätigung</p>
            <p className="text-xs text-red-600/80">
              Bitte tippe das Wort <span className="font-mono font-bold text-red-600">LOESCHEN</span> ein, um fortzufahren:
            </p>
            <input 
              type="text" 
              placeholder="Hier eintippen..."
              className="w-full px-3 py-2 rounded-lg border border-red-200 focus:outline-none focus:border-red-500 text-sm font-mono"
              onChange={(e) => { confirmText = e.target.value; }}
            />
          </div>
        </div>
      ),
      onConfirm: async () => {
        if (confirmText === 'LOESCHEN') {
          await db.vocabulary.clear();
          await db.learning_history.clear();
          await db.learning_sessions.clear();
          await db.user_settings.clear();
          setStatus('Datenbank zurückgesetzt.');
        } else {
          setStatus('Falsches Bestätigungswort. Datenbank wurde nicht gelöscht.');
        }
      }
    });
  };

  const [activeTab, setActiveTab] = useState<'settings' | 'vocab'>(viewMode === 'vocab' ? 'vocab' : 'settings');

  return (
    <div className="max-w-4xl mx-auto space-y-6 pb-12">
      <div className="flex items-center justify-between gap-4 mb-2">
        <h1 className="text-3xl font-bold text-brand-dark">
          {t('settings')}
        </h1>
        {activeTab === 'vocab' && (
          <button 
            onClick={() => setActiveTab('settings')}
            className="flex items-center gap-2 px-4 py-2 rounded-xl bg-brand/10 text-brand text-xs font-bold hover:bg-brand/20 transition-all"
          >
            <ChevronLeft size={16} />
            Zurück zu den Einstellungen
          </button>
        )}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        {/* Settings categories would go here, implemented similarly to original */}
        <p className="text-brand-dark/60 italic">Settings implementation continued...</p>
      </div>

      {modalConfig.isOpen && (
        <Modal 
          isOpen={modalConfig.isOpen}
          title={modalConfig.title}
          onClose={() => setModalConfig({ ...modalConfig, isOpen: false })}
          onConfirm={modalConfig.onConfirm}
          type={modalConfig.type}
        >
          {modalConfig.children}
        </Modal>
      )}
    </div>
  );
};
